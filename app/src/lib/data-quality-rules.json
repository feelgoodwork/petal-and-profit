  "notes": "Institutional memory for data-quality rules discovered during cleansing. Every rule should have a brief why-line so we can review and retire entries over time. Typo fixes and supply patterns are duplicated into classifier-data.js at module load (see loadRules in data-quality.ts) — edit here, not there.",

  "typo_fixes": {
    "gegera": { "to": "gerbera", "why": "misspelling in scanned invoices that caused gerbera to match 'daisy' base" },
    "gerbera daisy": { "to": "gerbera", "why": "composite name — gerbera is the actual flower" },
    "gerbera daisies": { "to": "gerberas", "why": "plural variant of above" },
    "soliago": { "to": "solidago", "why": "missing 'd' — common typo in recipes" },
    "solidgo": { "to": "solidago", "why": "dropped vowel variant" },
    "delphinum": { "to": "delphinium", "why": "dropped 'i'" },
    "liatrus": { "to": "liatris", "why": "vowel transposition" },
    "liatrice": { "to": "liatris", "why": "alternate romanization" },
    "alstromeria": { "to": "alstroemeria", "why": "dropped 'e'" },
    "alastromeria": { "to": "alstroemeria", "why": "letter transposition" },
    "rununculus": { "to": "ranunculus", "why": "vowel error" },
    "monestera": { "to": "monstera", "why": "extra 'e'" },
    "myrtl": { "to": "myrtle", "why": "dropped 'e'" },
    "blupleurum": { "to": "bupleurum", "why": "transposed letters" }
  },

  "not_a_flower_patterns": [
